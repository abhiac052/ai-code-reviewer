# AI Code Reviewer Configuration

# AWS Credentials (Uses your existing AWS credentials)
# No API key needed! Uses AWS IAM credentials from:
# - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# - AWS credentials file (~/.aws/credentials)
# - IAM role (if running on EC2/ECS)

# AWS Region
AWS_REGION=us-east-1

# Review Settings - Choose your model:
# BEST: Claude 4.0 Opus (if available in your region)
REVIEW_MODEL=anthropic.claude-opus-4-20250514-v1:0

# Alternative models (uncomment to use):
# REVIEW_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0  # Claude 3.5 Sonnet v2 (faster, cheaper)
# REVIEW_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0  # Claude 3.5 Sonnet v1 (original)
# REVIEW_MODEL=anthropic.claude-3-opus-20240229-v1:0      # Claude 3 Opus (older)

MAX_TOKENS=8192

# Dashboard Settings
DASHBOARD_PORT=3001
